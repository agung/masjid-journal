# ============================================
# Masjid Finance Tracker — Environment Variables
# Copy this file to .env.local and fill in values
# DO NOT commit .env.local to git
# ============================================

# --- Better Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=localsecretterlaluoverpower
BETTER_AUTH_URL=http://localhost:3000

# --- Database (Supabase PostgreSQL) ---
# From: Supabase dashboard > Project Settings > Database > Connection String > URI mode
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# --- Storage (Bukti Transaksi) ---
# STORAGE_PROVIDER=supabase (default) atau google_drive
STORAGE_PROVIDER=supabase

# Untuk STORAGE_PROVIDER=supabase:
# 1. Buat bucket "bukti-transaksi" di Supabase Dashboard > Storage (private)
# 2. Ambil URL dari Supabase Dashboard > Project Settings > API > Project URL
# 3. Service role key dari Supabase Dashboard > Project Settings > API > service_role key
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Untuk STORAGE_PROVIDER=google_drive:
# GOOGLE_DRIVE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_DRIVE_CLIENT_SECRET=GOCSPX-xxxxx
# GOOGLE_DRIVE_REFRESH_TOKEN=1//0gabcdef...
# GOOGLE_DRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Keuangan Masjid"
